NODE_ENV=development
PORT=3001
MONGODB_URI=mongodb://scada:scada@localhost:27017/scada?authSource=admin
MONGODB_DB=scada
TELEMETRY_RETENTION_DAYS=30
HISTORIAN_RETENTION_DAYS=365
HISTORIAN_HOURLY_RETENTION_DAYS=1095
ROLLUP_INTERVAL_MS=60000
